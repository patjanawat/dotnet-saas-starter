{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=saas_starter;Username=postgres;Password=postgres"
  },
  "Database": {
    "UseInMemory": true,
    "InMemoryName": "saas-starter-dev"
  },
  "Jwt": {
    "Issuer": "saas-starter",
    "Audience": "saas-starter-api",
    "SigningKey": "change-this-placeholder-signing-key-min-32",
    "AccessTokenMinutes": 60
  },
  "Email": {
    "Provider": "Disabled",
    "FromAddress": "noreply@example.local",
    "FromName": "SaaS Starter",
    "Host": "localhost",
    "Port": 2525,
    "UseSsl": false,
    "Username": "placeholder-user",
    "Password": "placeholder-password"
  },
  "Telemetry": {
    "ServiceName": "SaaS.Api"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "SaaS.Api"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
